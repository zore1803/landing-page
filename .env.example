# SendGrid configuration for the blog subscription endpoint (api/subscribe.js)
# Copy to .env.local for local dev, and set the same vars in Vercel Project Settings.

SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM=no-reply@datacircles.in
NOTIFY_EMAIL=rohit.zore@datacircles.in

# Same MongoDB connection string as the portal — subscribers are stored in the
# `subscribers` collection. Optionally set MONGODB_DB to override the database name.
MONGODB_URI=your_mongodb_connection_string_here
# MONGODB_DB=
